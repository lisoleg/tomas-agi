[Unit]
Description=TOMAS Flask API Server
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/tomas-agi/tomas_agi/sim
ExecStart=/usr/bin/python3 /root/tomas-agi/tomas_agi/sim/server.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
Environment="PYTHONUNBUFFERED=1"

[Install]
WantedBy=multi-user.target

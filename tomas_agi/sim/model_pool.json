    "rag":           { "default": "commandr",  "desc": "检索增强（RAG-EML）" },
    "multilingual":  { "default": "qwen3",     "desc": "多语 EML 对照" },
    "fallback":      { "default": "deepseek",  "desc": "兜底路由" }
